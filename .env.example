# ── Copy this to .env and fill in your keys ──────────────────────────────────
# Never commit .env to git

# Alpaca (Stocks) — free at alpaca.markets
# Use paper trading keys for testing
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_PAPER=true

# OANDA (Forex) — free practice account at oanda.com
OANDA_API_KEY=your_oanda_key_here
OANDA_ACCOUNT_ID=your_account_id_here
OANDA_ACCOUNT_TYPE=practice   # or: live

# Binance (Crypto) — only needed for placing orders, not price data
# Price data is free with no key
BINANCE_API_KEY=your_binance_key_here
BINANCE_SECRET_KEY=your_binance_secret_here
BINANCE_TESTNET=true

# Bot settings
POLL_INTERVAL_SECONDS=30
PORT=5000
